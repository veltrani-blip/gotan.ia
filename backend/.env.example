# --- Ambiente ---
ANA_ENVIRONMENT=development          # development | production
ANA_TIMEZONE=America/Sao_Paulo

# --- Google Cloud / Firestore ---
ANA_USE_FIRESTORE=false              # true em produção
ANA_GCP_PROJECT_ID=

# --- Vertex AI (Gemini 1.5 Pro) ---
ANA_USE_VERTEX=false
ANA_VERTEX_LOCATION=us-central1
ANA_VERTEX_MODEL=gemini-1.5-pro

# --- Twilio (alertas críticos) ---
ANA_USE_TWILIO=false
ANA_TWILIO_ACCOUNT_SID=
ANA_TWILIO_AUTH_TOKEN=
ANA_TWILIO_FROM_NUMBER=

# --- Event loop (minutos) ---
ANA_MEDICATION_CHECK_INTERVAL_MIN=1
ANA_HYDRATION_CHECK_INTERVAL_MIN=5
ANA_GEOFENCE_CHECK_INTERVAL_MIN=10
ANA_REMINDER_LOOKAHEAD_MIN=5
ANA_MEDICATION_ESCALATION_MIN=30
