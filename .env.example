# ── Anthropic ────────────────────────────────────────────────────────────────
# Chave privada. Nunca use NEXT_PUBLIC_ neste valor.
ANTHROPIC_API_KEY=

# ID de modelo habilitado na sua conta Anthropic.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Tempo máximo da chamada em milissegundos.
ANTHROPIC_TIMEOUT_MS=120000

# ── Supabase ─────────────────────────────────────────────────────────────────
# URL do projeto Supabase (público — pode aparecer no browser).
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (público — pode aparecer no browser). Nunca use a service role aqui.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role key (privada — NUNCA exponha ao browser nem comite este valor).
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Secret key (privada).
STRIPE_SECRET_KEY=

# Webhook signing secret (privado). Obtenha no painel Stripe → Webhooks.
STRIPE_WEBHOOK_SECRET=

# Price IDs dos planos de assinatura (copie do painel Stripe).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Price ID do pacote de créditos avulso.
STRIPE_PRICE_CREDITS_60=

# ── App ──────────────────────────────────────────────────────────────────────
# URL pública do app (usada nos redirects do Stripe Checkout).
NEXT_PUBLIC_APP_URL=http://localhost:3000
